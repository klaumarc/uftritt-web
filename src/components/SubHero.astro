---
import Lottie from "./Lottie.astro";

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  lottie?: string;
  lottieLabel?: string;
}
const { eyebrow, title, lead, lottie, lottieLabel } = Astro.props;
---

<section class="subhero section--yellow">
  <div class="container subhero-inner">
    <div class="subhero-text">
      {eyebrow && <span class="eyebrow" data-reveal>{eyebrow}</span>}
      <h1 data-reveal set:html={title} />
      {lead && <p class="subhero-lead" data-reveal>{lead}</p>}
      <slot name="hero-extra" />
    </div>
  </div>

  {
    lottie && (
      <div class="subhero-lottie" data-lottie-trigger aria-hidden="true">
        <Lottie src={lottie} hover={true} ariaLabel={lottieLabel} />
      </div>
    )
  }
</section>

<style>
  .subhero {
    position: relative;
    min-height: calc(100svh - 76px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }
  .subhero-inner {
    width: 100%;
    position: relative;
    z-index: 1;
    pointer-events: none; /* Maus erreicht das Lottie dahinter (Hover-Trigger) */
  }
  .subhero-text {
    /* etwas breiter als urspr. 620px, damit der Titel mehr Platz hat – aber
       gedeckelt, damit der Text NICHT unter das randständige Lottie läuft. */
    max-width: 780px;
    pointer-events: auto; /* Text/Links bleiben interaktiv */
  }
  .subhero .eyebrow {
    display: block;
    margin-bottom: 0.5rem;
  }
  .subhero-lead {
    font-size: clamp(1.3rem, 2.1vw, 1.9rem);
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-blue);
    margin-top: 1.5rem;
    max-width: 560px;
  }

  /* Lottie klebt bündig am rechten Screenrand und ist bewusst angeschnitten */
  .subhero-lottie {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translate(20%, -50%);
    width: min(52vw, 640px);
    height: min(52vw, 640px);
    cursor: var(--cur-hand);
    z-index: 0;
  }

  @media (max-width: 980px) {
    .subhero {
      min-height: auto;
      padding-block: clamp(2.5rem, 8vw, 4rem);
    }
    .subhero-text {
      max-width: none;
    }
    .subhero-lead {
      max-width: none; /* Lead über die ganze Breite */
    }
    /* Keine Icons im Header auf Unterseiten (mobil/tablet) */
    .subhero-lottie {
      display: none;
    }
  }
</style>
