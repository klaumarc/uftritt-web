---
// Referenzen-Strip: zeigt maximal 3 Projekte, Button linksbündig.
// Wird direkt unter den 3 Haupttätigkeiten der Dienstleistungsseiten platziert.
import Button from "./Button.astro";
import type { Project } from "../data/projects";
interface Props {
  title: string;
  projects: Project[];
}
const { title, projects } = Astro.props;
const items = projects.slice(0, 3);
---

{items.length > 0 && (
<section class="section section--soft">
  <div class="container">
    <header class="section-head" data-reveal>
      <span class="eyebrow">Referenzen</span>
      <h2>{title}</h2>
    </header>
    <div class="portfolio">
      {
        items.map((p) => (
          <a href={`/projekte/${p.slug}`} class="ref-card" aria-label={p.title} data-reveal>
            <img class="ref-img" src={p.image} alt={p.title} loading="lazy" />
            <span class="ref-overlay">
              <span class="ref-cat">{p.categories.join(" · ")}</span>
              <span class="ref-title">{p.title}</span>
            </span>
          </a>
        ))
      }
    </div>
    <div class="left-cta" data-reveal>
      <Button href="/projekte" variant="blue">Alle Projekte ansehen</Button>
    </div>
  </div>
</section>
)}

<style>
  .section-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .portfolio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.5rem, 1.2vw, 0.9rem);
  }
  .ref-card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f1f4f8;
  }
  .ref-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.85s var(--ease);
  }
  .ref-card:hover .ref-img,
  .ref-card:focus-visible .ref-img {
    transform: scale(1.05);
  }
  .ref-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 1.5rem;
    text-align: center;
    background: rgba(1, 64, 128, 0.82);
    color: #fff;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .ref-card:hover .ref-overlay,
  .ref-card:focus-visible .ref-overlay {
    opacity: 1;
  }
  .ref-cat {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }
  .ref-title {
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    font-weight: 700;
    line-height: 1.15;
  }
  .left-cta {
    display: flex;
    justify-content: flex-start;
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
  }
  /* Touch: Titel/Kategorie dauerhaft als Badge unten, Bild bleibt Fokus */
  @media (hover: none) {
    .ref-overlay {
      opacity: 1;
      background: linear-gradient(
        to top,
        rgba(1, 32, 64, 0.82),
        rgba(1, 32, 64, 0) 58%
      );
      justify-content: flex-end;
      align-items: flex-start;
      text-align: left;
      padding: 0.8rem 0.9rem;
      gap: 0.1rem;
    }
    .ref-cat {
      font-size: 0.62rem;
    }
    .ref-title {
      font-size: 1rem;
    }
  }
  /* Mobile: Referenzen als horizontaler Swipe (kompakter) */
  @media (max-width: 760px) {
    .portfolio {
      display: flex;
      overflow-x: auto;
      gap: 0.6rem;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      margin-inline: calc(50% - 50vw);
      padding-inline: calc(50vw - 50%);
    }
    .portfolio::-webkit-scrollbar {
      display: none;
    }
    .ref-card {
      flex: 0 0 72%;
      scroll-snap-align: start;
    }
  }
</style>
