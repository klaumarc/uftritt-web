---
import Lottie from "./Lottie.astro";

const nav = [
  { label: "Agentur", href: "/agentur" },
  {
    label: "Angebot",
    href: "/angebot",
    children: [
      { label: "Grafikdesign", href: "/angebot/grafikdesign" },
      { label: "Webdesign und Entwicklung", href: "/angebot/webdesign" },
      { label: "Videoproduktion", href: "/angebot/videoproduktion" },
      { label: "App-Entwicklung", href: "/angebot/applikationsentwicklung" },
      { label: "Marketingbegleitung", href: "/angebot/marketingbegleitung" },
      { label: "Magazinbetreuung", href: "/angebot/magazinbetreuung" },
    ],
  },
  { label: "Projekte", href: "/projekte" },
  { label: "Partner", href: "/partner" },
  { label: "News", href: "/aktuell" },
  { label: "Kontakt", href: "/kontakt" },
];

const social = [
  { key: "linkedin", label: "LinkedIn", href: "https://www.linkedin.com/company/uftritt-gmbh/", icon: "/img/icons/linkedin-icon.svg" },
  { key: "instagram", label: "Instagram", href: "https://www.instagram.com/uftritt/", icon: "/img/icons/instagram-icon.svg" },
  { key: "facebook", label: "Facebook", href: "https://www.facebook.com/profile.php?id=61551877650400", icon: "/img/icons/facebook-icon.svg" },
  { key: "youtube", label: "YouTube", href: "https://www.youtube.com/@UftrittGmbH", icon: "/img/icons/youtube-icon.svg" },
];

const angebotChildren = nav.find((n) => n.children)?.children ?? [];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="header-logo" aria-label="Uftritt Startseite" data-lottie-trigger>
      <Lottie src="/lottie/logo.json" hover={true} ariaLabel="Uftritt" />
    </a>

    <button
      class="menu-trigger"
      type="button"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="menu-overlay"
    >
      Menü
    </button>

    <ul class="header-social" aria-label="Social Media">
      {
        social.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class={`social--${s.key}`}>
              <img src={s.icon} alt="" />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

{/* Mobiler Menü-Balken unten (Daumen-erreichbar) */}
<button
  class="menu-fab"
  type="button"
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-controls="menu-overlay"
>
  Menü
</button>

{/* ---------- Vollbild-Menü ---------- */}
<div class="menu-overlay" id="menu-overlay" role="dialog" aria-modal="true" aria-label="Menü" hidden>
  <div class="container menu-overlay-top">
    <a href="/" class="header-logo" aria-label="Uftritt Startseite">
      <img src="/logo/uftritt-blau.svg" alt="Uftritt" width="130" height="42" />
    </a>
    <button class="menu-close" type="button" aria-label="Menü schliessen">
      <svg viewBox="0 0 32 32" width="32" height="32" aria-hidden="true">
        <path d="M6 6l20 20M26 6L6 26" stroke="currentColor" stroke-width="4" stroke-linecap="square" />
      </svg>
    </button>
  </div>

  <nav class="menu-nav" aria-label="Hauptnavigation">
    <ul>
      {nav.map((item, i) => (
        <li style={`--i:${i}`} class={item.children ? "has-sub" : undefined}>
          <a href={item.href} data-sub={item.children ? "" : undefined}>
            <span class="m-arrow" aria-hidden="true"><i></i></span><span class="m-label">{item.label}</span>
          </a>
          {item.children && (
            <button class="submenu-toggle" type="button" aria-label={`${item.label} – Unterpunkte`}>
              <span class="sub-arrow" aria-hidden="true"></span>
            </button>
          )}
          {item.children && (
            <ul class="submenu" aria-label={`${item.label} – Dienstleistungen`}>
              {item.children.map((c) => (
                <li>
                  <a href={c.href}>
                    <span class="m-arrow" aria-hidden="true"><i></i></span><span class="m-label">{c.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <ul class="menu-social">
      {social.map((s, i) => (
        <li style={`--i:${nav.length + i}`}>
          <a href={s.href} target="_blank" rel="noopener">
            <span class="m-arrow" aria-hidden="true"><i></i></span><span class="m-label">{s.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  {angebotChildren.length > 0 && (
    <div class="submenu-panel" id="submenu-panel" role="dialog" aria-label="Angebot – Dienstleistungen" hidden>
      <div class="container submenu-panel-top">
        <button class="submenu-back" type="button">
          <span class="sub-back-arrow" aria-hidden="true"></span>
          Zurück
        </button>
        <button class="submenu-panel-close" type="button" aria-label="Menü schliessen">
          <svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true"><path d="M6 6l20 20M26 6L6 26" stroke="currentColor" stroke-width="3.4" stroke-linecap="square" /></svg>
        </button>
      </div>
      <nav class="submenu-panel-nav" aria-label="Angebot – Dienstleistungen">
        <ul>
          <li><a href="/angebot">Übersicht</a></li>
          {angebotChildren.map((c) => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-yellow);
  }
  .header-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 76px;
  }
  /* Box exakt auf die Logo-Proportion (Lottie 460x151) -> kein Zentrier-Spalt,
     Header-Lottie und Overlay-SVG liegen deckungsgleich übereinander. */
  .header-logo {
    display: block;
    height: 50px;
    aspect-ratio: 460 / 151;
  }
  .header-logo img {
    height: 50px;
    width: auto;
  }

  /* Exakt in der Container-Mitte (50 %) – deckt sich mit dem X im Overlay */
  .menu-trigger {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: var(--cur-hand);
    font-family: var(--font-base);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-blue);
    padding: 0.65rem 0.6rem;
    transition: transform 0.32s var(--ease);
  }
  /* Hover wie die SoMe-Icons: leichter Lift, keine Unterstreichungs-Linie – Revision Jeffrey */
  .menu-trigger:hover {
    transform: translate(-50%, -50%) translateY(-3px);
  }

  .header-social {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .header-social a {
    display: grid;
    place-items: center;
    width: 24px;
    height: 26px;
    transition: transform 0.32s var(--ease);
  }
  .header-social a:hover {
    transform: translateY(-3px);
  }
  /* Optisch ausgeglichene Icon-Grössen (unterschiedliche viewBox-Proportionen) */
  .header-social img {
    display: block;
    width: auto;
  }
  .social--linkedin img,
  .social--instagram img {
    height: 18px;
  }
  .social--facebook img {
    height: 17px; /* schmales, hohes "f" – etwas kleiner, damit es nicht dominiert */
  }
  .social--youtube img {
    height: 15px; /* breites Icon – über Höhe begrenzt */
  }

  /* ---------- Overlay ---------- */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--color-yellow);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transition: opacity 0.55s var(--ease);
  }
  .menu-overlay.is-open {
    opacity: 1;
  }
  .menu-overlay[hidden] {
    display: none;
  }
  .menu-overlay-top {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 76px;
  }
  /* X erscheint an derselben Stelle wie der "Menü"-Trigger (oben zentriert) */
  .menu-close {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: var(--cur-hand);
    color: var(--color-blue);
    padding: 0.5rem;
    transition: transform 0.4s var(--ease);
  }
  .menu-close:hover {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .menu-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: safe center;
    align-items: flex-start;
    text-align: left;
    width: 100%;
    /* linksbündig, aber Block beginnt ~Bildschirmmitte + 10% (≈60%) */
    padding-left: 58vw;
    padding-right: var(--gutter);
    padding-block: 0 8vh;
    overflow-y: auto;
  }
  @media (max-width: 820px) {
    .menu-nav {
      /* linksbündig, exakt an der Container-Kante (= Logo oben) orientiert */
      padding-left: calc((100vw - var(--container)) / 2 + var(--gutter));
    }
    .menu-nav > ul {
      gap: clamp(1.9rem, 6vw, 2.9rem); /* mehr Abstand zwischen den Reitern */
    }
    .menu-nav > ul li a {
      font-size: clamp(2.6rem, 9vw, 3.4rem); /* etwas grössere Schrift */
    }
  }
  /* Touch-Geräte: kein Hover -> Pfeil-Animation weglassen (schob sich sonst über den Text) */
  @media (hover: none) {
    .m-arrow {
      display: none;
    }
  }
  .menu-nav > ul li a {
    display: inline-flex;
    align-items: center;
    font-weight: 700;
    line-height: 1.15;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    color: var(--color-blue);
  }
  /* Marken-Pfeil gleitet bei Hover links rein, Label rückt nach */
  .m-arrow {
    display: inline-block;
    max-width: 0;
    margin-right: 0;
    overflow: visible; /* Pfeil bleibt beim Rausgleiten nach links sichtbar */
    transition: max-width 0.6s var(--ease), margin-right 0.6s var(--ease);
  }
  .m-arrow i {
    display: block;
    width: 0.95em;
    height: 0.72em;
    background-color: var(--color-blue);
    -webkit-mask: url("/img/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
    mask: url("/img/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
    opacity: 0;
    transform: translateX(-16px);
    transition: opacity 0.5s var(--ease), transform 0.6s var(--ease);
  }
  .menu-nav > ul li a:hover .m-arrow,
  .menu-nav > ul li a:focus-visible .m-arrow {
    max-width: 0.95em;
    margin-right: 0.45em;
  }
  .menu-nav > ul li a:hover .m-arrow i,
  .menu-nav > ul li a:focus-visible .m-arrow i {
    opacity: 1;
    transform: translateX(0);
  }
  .menu-nav > ul {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(0.6rem, 1.8vw, 1.4rem);
  }
  .menu-nav > ul > li {
    position: relative;
  }

  /* ---------- Submenu (Dienstleistungen, rechts neben "Angebot") ---------- */
  .submenu {
    position: absolute;
    left: 100%;
    top: 50%;
    /* Padding statt Margin: überbrückt die Lücke als Hover-Fläche */
    padding-left: clamp(1.5rem, 3vw, 3.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(0.25rem, 0.8vw, 0.6rem);
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-50%) translateX(10px);
    transition: opacity 0.45s var(--ease), transform 0.6s var(--ease);
  }
  .menu-nav > ul > li.has-sub:hover .submenu,
  .menu-nav > ul > li.has-sub:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }
  .menu-nav .submenu li a {
    font-size: clamp(0.95rem, 1.4vw, 1.25rem);
    font-weight: 700;
    line-height: 1.2;
  }
  /* "Angebot" selbst zeigt keinen Pfeil – der Hover öffnet stattdessen das Submenu */
  @media (min-width: 821px) {
    .menu-nav > ul > li.has-sub > a:hover .m-arrow,
    .menu-nav > ul > li.has-sub > a:focus-visible .m-arrow {
      max-width: 0;
      margin-right: 0;
    }
    .menu-nav > ul > li.has-sub > a:hover .m-arrow i,
    .menu-nav > ul > li.has-sub > a:focus-visible .m-arrow i {
      opacity: 0;
      transform: translateX(-16px);
    }
  }
  /* Desktop: kein Toggle nötig (Submenu öffnet per Hover) */
  .submenu-toggle {
    display: none;
  }
  /* Mobile: Chevron neben "Angebot" öffnet ein eigenes Panel; Inline-Submenu aus */
  @media (max-width: 820px) {
    .menu-nav > ul > li.has-sub {
      display: flex;
      align-items: center;
      column-gap: 0.4rem;
    }
    .submenu-toggle {
      display: inline-grid;
      place-items: center;
      background: none;
      border: none;
      color: var(--color-blue);
      padding: 0.2rem;
      cursor: var(--cur-hand);
    }
    .submenu {
      display: none;
    }
  }

  /* ---------- Mobile-Submenu-Panel (fliegt von rechts ein) ---------- */
  .submenu-panel {
    position: fixed;
    inset: 0;
    z-index: 210;
    background: var(--color-yellow);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.45s var(--ease);
  }
  .submenu-panel.is-open {
    transform: translateX(0);
  }
  .submenu-panel[hidden] {
    display: none;
  }
  .submenu-panel-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 76px;
  }
  .submenu-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: none;
    color: var(--color-blue);
    font-family: var(--font-base);
    font-weight: 700;
    font-size: 1.1rem;
    cursor: var(--cur-hand);
  }
  .submenu-back:hover {
    color: var(--color-pink);
  }
  .sub-back-arrow {
    display: inline-block;
    width: 1.05rem;
    height: 1.05rem;
    background: var(--color-blue);
    -webkit-mask: url("/img/icons/pfeil-links-blau.svg") no-repeat center / contain;
    mask: url("/img/icons/pfeil-links-blau.svg") no-repeat center / contain;
  }
  .submenu-back:hover .sub-back-arrow {
    background: var(--color-pink);
  }
  .sub-arrow {
    display: block;
    width: 1.35rem;
    height: 1.35rem;
    background: var(--color-blue);
    -webkit-mask: url("/img/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
    mask: url("/img/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
  }
  .submenu-panel-close {
    background: none;
    border: none;
    color: var(--color-blue);
    cursor: var(--cur-hand);
    padding: 0.3rem;
    line-height: 0;
    transition: transform 0.4s var(--ease);
  }
  .submenu-panel-close:hover {
    transform: rotate(90deg);
  }
  .submenu-panel-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 calc((100vw - var(--container)) / 2 + var(--gutter)) 8vh;
    overflow-y: auto;
  }
  .submenu-panel-nav ul {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1rem, 3.5vw, 1.5rem);
  }
  .submenu-panel-nav li a {
    font-weight: 700;
    font-size: clamp(1.5rem, 5.5vw, 2rem);
    color: var(--color-blue);
  }
  @media (min-width: 821px) {
    .submenu-panel {
      display: none;
    }
  }
  .menu-nav > ul.menu-social {
    margin-top: 2.75rem;
    gap: 0.05rem;
  }
  .menu-nav > ul.menu-social li a {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-blue);
  }
  .menu-nav > ul.menu-social li a:hover {
    text-decoration: none;
  }

  /* Stagger-Einblendung der Menüpunkte (nur oberste Ebene, nicht Submenu) */
  .menu-overlay .menu-nav > ul > li {
    opacity: 0;
    transform: translateY(18px);
  }
  .menu-overlay.is-open .menu-nav > ul > li {
    animation: menuIn 0.5s var(--ease) forwards;
    animation-delay: calc(120ms + var(--i, 0) * 60ms);
  }
  @keyframes menuIn {
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-overlay,
    .menu-overlay .menu-nav li {
      transition: none;
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* ---------- Mobile-Navigation: "Menü" als Balken unten ---------- */
  .menu-fab {
    display: none; /* Desktop: kein Balken, "Menü" sitzt oben zentriert */
  }

  @media (max-width: 720px) {
    /* Top-Bar: Logo links, Social rechts – "Menü" wandert nach unten */
    .header-inner {
      justify-content: space-between;
      gap: 1rem;
    }
    .menu-trigger {
      display: none;
    }

    /* Pinker Menü-Balken, unten zentriert, gut mit dem Daumen erreichbar */
    .menu-fab {
      display: block;
      position: fixed;
      left: 50%;
      bottom: clamp(1rem, 4vw, 1.75rem);
      transform: translateX(-50%);
      z-index: 150;
      background: var(--color-pink);
      color: #fff;
      font-family: var(--font-base);
      font-weight: 700;
      font-size: 1.05rem;
      letter-spacing: 0.02em;
      border: none;
      cursor: var(--cur-hand);
      padding: 0.85rem 2.4rem;
      transition: transform 0.45s var(--ease), opacity 0.3s var(--ease);
    }
    /* Beim Runterscrollen wegfahren, beim Hochscrollen zurück */
    .menu-fab.is-hidden {
      transform: translate(-50%, 220%);
      opacity: 0;
      pointer-events: none;
    }

    /* Schliessen-Kreuz an derselben Stelle unten: blaues X im gelben Kreis */
    .menu-close {
      position: fixed;
      left: 50%;
      top: auto;
      bottom: clamp(1rem, 4vw, 1.75rem);
      transform: translateX(-50%);
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background: var(--color-yellow);
      color: var(--color-blue);
      display: grid;
      place-items: center;
      padding: 0;
    }
    .menu-close:hover {
      transform: translateX(-50%) rotate(90deg);
    }
  }
</style>

<script>
  const trigger = document.querySelector<HTMLButtonElement>(".menu-trigger");
  const fab = document.querySelector<HTMLButtonElement>(".menu-fab");
  const overlay = document.querySelector<HTMLElement>("#menu-overlay");
  const closeBtn = overlay?.querySelector<HTMLButtonElement>(".menu-close");
  const panel = overlay?.querySelector<HTMLElement>(".submenu-panel");
  const links = overlay?.querySelectorAll<HTMLAnchorElement>("a:not([data-sub])");
  const triggers = [trigger, fab].filter(Boolean) as HTMLButtonElement[];

  function openMenu() {
    if (!overlay) return;
    overlay.hidden = false;
    // reflow, damit die opacity-Transition greift
    void overlay.offsetWidth;
    overlay.classList.add("is-open");
    // Scroll sperren. Die Layout-Breite bleibt dank scrollbar-gutter:stable (global.css)
    // unverändert -> Logo und X bleiben exakt an Ort.
    document.documentElement.style.overflow = "hidden";
    triggers.forEach((t) => t.setAttribute("aria-expanded", "true"));
    closeBtn?.focus();
  }
  function closeMenu() {
    if (!overlay) return;
    if (panel) {
      panel.classList.remove("is-open");
      panel.hidden = true;
    }
    overlay.classList.remove("is-open");
    document.documentElement.style.overflow = "";
    triggers.forEach((t) => t.setAttribute("aria-expanded", "false"));
    const onEnd = () => {
      overlay.hidden = true;
      overlay.removeEventListener("transitionend", onEnd);
    };
    overlay.addEventListener("transitionend", onEnd);
    (fab || trigger)?.focus();
  }

  triggers.forEach((t) => t.addEventListener("click", openMenu));
  closeBtn?.addEventListener("click", closeMenu);
  links?.forEach((l) => l.addEventListener("click", closeMenu));

  // Mobile-Submenu-Panel (fliegt von rechts ein)
  const isMobileMenu = () => window.matchMedia("(max-width: 820px)").matches;
  function openPanel() {
    if (!panel) return;
    panel.hidden = false;
    void panel.offsetWidth;
    panel.classList.add("is-open");
  }
  function closePanel() {
    if (!panel) return;
    panel.classList.remove("is-open");
    const onEnd = () => {
      panel.hidden = true;
      panel.removeEventListener("transitionend", onEnd);
    };
    panel.addEventListener("transitionend", onEnd);
  }
  overlay?.querySelectorAll<HTMLElement>("[data-sub]").forEach((a) =>
    a.addEventListener("click", (e) => {
      if (isMobileMenu()) {
        e.preventDefault();
        openPanel();
      }
    })
  );
  overlay?.querySelectorAll<HTMLButtonElement>(".submenu-toggle").forEach((btn) =>
    btn.addEventListener("click", openPanel)
  );
  panel?.querySelector<HTMLButtonElement>(".submenu-back")?.addEventListener("click", closePanel);
  panel
    ?.querySelector<HTMLButtonElement>(".submenu-panel-close")
    ?.addEventListener("click", () => {
      closePanel();
      closeMenu();
    });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay && !overlay.hidden) closeMenu();
  });

  // Mobiler Menü-Balken: beim Runterscrollen ausblenden, beim Hochscrollen einblenden
  let lastY = window.scrollY;
  let ticking = false;
  function onScroll() {
    const y = window.scrollY;
    if (fab && (overlay?.hidden ?? true)) {
      if (y > lastY && y > 120) fab.classList.add("is-hidden");
      else fab.classList.remove("is-hidden");
    }
    lastY = y;
    ticking = false;
  }
  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    },
    { passive: true }
  );
</script>
