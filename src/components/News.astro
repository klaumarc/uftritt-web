---
import { news } from "../data/news";

interface Props {
  limit?: number;
  showFilter?: boolean;
}
const { limit, showFilter = true } = Astro.props;
const items = limit ? news.slice(0, limit) : news;
const yearOf = (d: string) => d.match(/\d{4}/)?.[0] ?? d;
const years = Array.from(new Set(items.map((n) => yearOf(n.date)))).sort(
  (a, b) => Number(b) - Number(a)
);
const filters = ["Alle", ...years];
---

<div class="news">
  {
    showFilter && (
      <div class="news-filter" role="tablist" aria-label="News filtern">
        {filters.map((f, i) => (
          <button
            class:list={["news-chip", { "is-active": i === 0 }]}
            type="button"
            data-filter={f}
          >
            {f}
          </button>
        ))}
      </div>
    )
  }

  <ul class="news-grid">
    {
      items.map((n) => (
        <li class="news-item" data-year={yearOf(n.date)}>
          <a class="news-card" href={`/aktuell/${n.slug}`}>
            <span class="news-media">
              <img src={n.image} alt={n.title} loading="lazy" />
            </span>
            <span class="news-body">
              <span class="news-meta">
                <span class="news-cat">{n.category}</span>
                <span class="news-date">{n.date}</span>
              </span>
              <span class="news-title">{n.title}</span>
              <span class="news-excerpt">{n.excerpt}</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .news-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .news-chip {
    font-family: var(--font-base);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-blue);
    background: transparent;
    border: 2px solid rgba(1, 64, 128, 0.25);
    padding: 0.5rem 1.1rem;
    cursor: pointer;
    transition: background 0.4s var(--ease), color 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  .news-chip:hover {
    border-color: var(--color-blue);
  }
  .news-chip.is-active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: #fff;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  .news-item.is-hidden {
    display: none;
  }
  .news-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: var(--color-blue);
  }
  .news-media {
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-bg-soft);
  }
  .news-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    transition: transform 0.85s var(--ease);
  }
  .news-card:hover .news-media img {
    transform: scale(1.05);
  }
  .news-body {
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .news-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.85rem;
  }
  .news-cat {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .news-date {
    color: var(--color-muted);
  }
  .news-title {
    font-weight: 700;
    font-size: 1.3rem;
    line-height: 1.2;
  }
  .news-excerpt {
    color: var(--color-ink);
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>(".news");
  if (root) {
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>(".news-chip"));
    const items = Array.from(root.querySelectorAll<HTMLElement>(".news-item"));
    chips.forEach((chip) =>
      chip.addEventListener("click", () => {
        const filter = chip.dataset.filter;
        chips.forEach((c) => c.classList.toggle("is-active", c === chip));
        items.forEach((it) => {
          const show = filter === "Alle" || it.dataset.year === filter;
          it.classList.toggle("is-hidden", !show);
        });
      })
    );
  }
</script>
