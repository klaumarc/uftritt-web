---
import { team } from "../data/team";

interface Props {
  carousel?: boolean;
}
const { carousel = false } = Astro.props;
---

<div class:list={["team-slider", { "is-carousel": carousel }]}>
  <ul class:list={["team-track", { "is-carousel": carousel }]}>
    {
      team.map((m) => (
        <li class="team-item">
          <button
            class="team-member"
            type="button"
            data-team-open
            data-name={m.name}
            data-role={m.role}
            data-bio={m.bio}
            data-email={m.email}
            data-photo={m.photo}
          >
            <span class="team-photo">
              <img src={m.photo} alt={m.name} loading="lazy" />
              <span class="team-caption">
                <span class="team-name">{m.name}</span>
                <span class="team-role">{m.role}</span>
              </span>
              <span class="team-plus" aria-hidden="true">+</span>
            </span>
          </button>
        </li>
      ))
    }
  </ul>

  {
    carousel && (
      <>
        <button class="team-nav team-nav--prev" type="button" aria-label="Vorherige Mitarbeiter" data-team-prev>
          <span class="team-nav-arrow team-nav-arrow--left" />
        </button>
        <button class="team-nav team-nav--next" type="button" aria-label="Nächste Mitarbeiter" data-team-next>
          <span class="team-nav-arrow" />
        </button>
      </>
    )
  }
</div>

{/* ---------- Lightbox ---------- */}
<div class="team-lightbox" id="team-lightbox" role="dialog" aria-modal="true" aria-labelledby="tl-name" hidden>
  <div class="team-lightbox-backdrop" data-team-close></div>
  <div class="team-lightbox-panel" role="document">
    <button class="team-lightbox-close" type="button" aria-label="Schliessen" data-team-close>
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
        <path d="M7 7l18 18M25 7L7 25" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
      </svg>
    </button>
    <div class="team-lightbox-media">
      <img id="tl-photo" src="" alt="" />
    </div>
    <div class="team-lightbox-body">
      <h3 id="tl-name"></h3>
      <p class="tl-role" id="tl-role"></p>
      <p class="tl-bio" id="tl-bio"></p>
      <a class="tl-email" id="tl-email" href="#"></a>
    </div>
  </div>
</div>

<style>
  .team-slider {
    position: relative;
  }

  /* ---------- Raster-Variante (Standard, z. B. /agentur) ---------- */
  .team-track {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.5rem);
    align-items: start;
    padding-block: 0.5rem;
  }
  .team-item:nth-child(even) {
    margin-top: clamp(1.5rem, 4vw, 3.5rem);
  }
  @media (max-width: 1100px) {
    .team-track:not(.is-carousel) {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 760px) {
    .team-track:not(.is-carousel) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .team-track:not(.is-carousel) {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .team-item:nth-child(even) {
      margin-top: 0;
    }
  }

  /* ---------- Karussell-Variante (Startseite): IMMER Slider, N sichtbar ----------
     Alle Mitarbeiter ohne Pfeile anzeigen; passt nicht alles in die Breite,
     wird horizontal geswipt/gescrollt. Je nach Platz 5 / 4 / 3 / 2 / 1 sichtbar.
     Links content-bündig, rechts bis zum Bildschirmrand -> nächste Person
     wird vom Rand her angeschnitten (wie auf uftritt.ch). */
  .team-track.is-carousel {
    --g: clamp(0.75rem, 1.5vw, 1.5rem);
    --vis: 5;
    display: flex;
    grid-template-columns: none;
    gap: var(--g);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
    margin-right: calc(50% - 50vw); /* rechts full-bleed bis Bildschirmrand */
    padding-bottom: 0.25rem;
  }
  .team-track.is-carousel::-webkit-scrollbar {
    display: none;
  }
  /* Breite je sichtbarer Person, bezogen auf die Container-Breite (90vw - Gutter),
     unabhängig vom rechts ausgebrochenen Track. */
  .team-track.is-carousel .team-item {
    flex: 0 0
      calc((90vw - 2 * var(--gutter) - (var(--vis) - 1) * var(--g)) / var(--vis));
    scroll-snap-align: start;
    scroll-snap-stop: always; /* nicht über Personen hinwegspringen */
  }
  .team-track.is-carousel .team-item:nth-child(even) {
    margin-top: clamp(1.5rem, 4vw, 3.5rem); /* Zickzack-Höhenversatz (wie im Raster) */
  }
  @media (max-width: 1200px) { .team-track.is-carousel { --vis: 4; } }
  @media (max-width: 980px)  { .team-track.is-carousel { --vis: 3; } }
  @media (max-width: 680px)  { .team-track.is-carousel { --vis: 2; } }
  @media (max-width: 480px)  { .team-track.is-carousel { --vis: 1.12; } }

  /* ---------- Slider-Navigation (Pfeile) ----------
     Erscheinen nur, wenn der Slider tatsächlich überläuft UND ein Maus-Zeiger
     vorhanden ist (Desktop/kleines Fenster). Touch-Geräte swipen -> keine Pfeile. */
  .team-nav {
    position: absolute;
    top: 33%;
    transform: translateY(-50%);
    z-index: 3;
    display: none;
    place-items: center;
    width: 46px;
    height: 46px;
    border: none;
    background: var(--color-blue);
    color: #fff;
    cursor: pointer;
    transition: background 0.3s var(--ease);
  }
  .team-nav:hover {
    background: var(--color-blue-dark);
  }
  .team-nav--prev { left: 0; }
  .team-nav--next { right: 0; }
  .team-nav-arrow {
    width: 20px;
    height: 14px;
    background-color: currentColor;
    -webkit-mask: url("/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
    mask: url("/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
  }
  .team-nav-arrow--left {
    transform: rotate(180deg);
  }
  @media (hover: hover) and (pointer: fine) {
    .team-slider.is-carousel.has-overflow .team-nav {
      display: grid;
    }
  }

  .team-member {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-base);
    color: var(--color-blue);
  }
  .team-photo {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgba(1, 64, 128, 0.06);
  }
  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    transition: transform 0.7s var(--ease);
  }
  .team-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(1, 32, 64, 0.6), transparent 42%);
    pointer-events: none;
  }
  .team-member:hover .team-photo img {
    transform: scale(1.05);
  }
  .team-caption {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .team-plus {
    position: absolute;
    right: 0.7rem;
    bottom: 0.7rem;
    z-index: 2;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--color-blue);
    color: #fff;
    font-size: 1.4rem;
    line-height: 1;
    font-weight: 700;
    transform: translateY(6px);
    opacity: 0;
    transition: transform 0.45s var(--ease), opacity 0.45s var(--ease);
  }
  .team-member:hover .team-plus,
  .team-member:focus-visible .team-plus {
    transform: none;
    opacity: 1;
  }
  .team-name {
    color: #fff;
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.1;
  }
  .team-role {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0.92;
  }

  /* ---------- Lightbox ---------- */
  .team-lightbox {
    position: fixed;
    inset: 0;
    z-index: 210;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 3rem);
  }
  .team-lightbox[hidden] {
    display: none;
  }
  .team-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(1, 32, 64, 0.55);
    backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity 0.45s var(--ease);
  }
  .team-lightbox.is-open .team-lightbox-backdrop {
    opacity: 1;
  }
  .team-lightbox-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    width: min(900px, 100%);
    max-height: 90vh;
    overflow: auto;
    background: #fff;
    border-radius: 0;
    padding: clamp(1.5rem, 3vw, 2.75rem);
    transform: translateY(16px) scale(0.98);
    opacity: 0;
    transition: transform 0.55s var(--ease), opacity 0.55s var(--ease);
  }
  .team-lightbox.is-open .team-lightbox-panel {
    transform: none;
    opacity: 1;
  }
  .team-lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--color-blue);
    cursor: pointer;
    padding: 0.4rem;
    z-index: 2;
    transition: transform 0.4s var(--ease);
  }
  .team-lightbox-close:hover {
    transform: rotate(90deg);
  }
  /* Volles Bild zeigen – Köpfe nicht stark anschneiden */
  .team-lightbox-media img {
    width: 100%;
    height: auto;
    max-height: 72vh;
    object-fit: contain;
    object-position: left top; /* Bild linksbündig + oben mit dem Text */
    border-radius: 0;
  }
  .team-lightbox-body h3 {
    color: var(--color-blue);
    margin-bottom: 0.15rem;
  }
  .tl-role {
    color: var(--color-blue);
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .tl-bio {
    line-height: 1.7;
  }
  .tl-email {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-muted);
    font-weight: 600;
  }
  .tl-email:hover {
    color: var(--color-blue);
  }

  @media (max-width: 700px) {
    .team-lightbox-panel {
      grid-template-columns: 1fr;
    }
    .team-lightbox-media img {
      max-height: 48vh;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .team-lightbox-backdrop,
    .team-lightbox-panel {
      transition: none;
    }
  }
</style>

<script>
  // ---------- Karussell mit Endlos-Loop (nur Startseite, nur Mobile) ----------
  const carousel = document.querySelector<HTMLElement>(".team-track.is-carousel");
  const teamSlider = document.querySelector<HTMLElement>(".team-slider.is-carousel");
  if (carousel) {
    // Endlos-Loop nur auf dem Phone (Touch-Swipe)
    if (window.matchMedia("(max-width: 760px)").matches) {
      // Items duplizieren (3 Sets), Start im mittleren Set → nahtloser Loop in beide Richtungen
      const originals = Array.from(carousel.children);
      originals.forEach((n) => carousel.appendChild(n.cloneNode(true)));
      originals.forEach((n) => carousel.insertBefore(n.cloneNode(true), carousel.firstChild));

      const setWidth = () => carousel.scrollWidth / 3;
      requestAnimationFrame(() => {
        carousel.scrollLeft = setWidth();
      });

      let raf = 0;
      carousel.addEventListener(
        "scroll",
        () => {
          if (raf) return;
          raf = requestAnimationFrame(() => {
            raf = 0;
            const w = setWidth();
            if (carousel.scrollLeft >= 2 * w) carousel.scrollLeft -= w;
            else if (carousel.scrollLeft <= 0) carousel.scrollLeft += w;
          });
        },
        { passive: true }
      );
    }

    // Überlauf-Erkennung -> Pfeile zeigen (per CSS nur auf Maus-Geräten sichtbar)
    const updateOverflow = () => {
      if (!teamSlider) return;
      teamSlider.classList.toggle(
        "has-overflow",
        carousel.scrollWidth - carousel.clientWidth > 4
      );
    };
    updateOverflow();
    window.addEventListener("resize", updateOverflow);

    // Pfeile: um eine Personen-Breite weiterscrollen
    const stepWidth = () => {
      const item = carousel.querySelector<HTMLElement>(".team-item");
      const styles = getComputedStyle(carousel);
      const gap = parseFloat(styles.columnGap || styles.gap || "16") || 16;
      return item
        ? item.getBoundingClientRect().width + gap
        : carousel.clientWidth * 0.8;
    };
    document
      .querySelector<HTMLButtonElement>("[data-team-prev]")
      ?.addEventListener("click", () =>
        carousel.scrollBy({ left: -stepWidth(), behavior: "smooth" })
      );
    document
      .querySelector<HTMLButtonElement>("[data-team-next]")
      ?.addEventListener("click", () =>
        carousel.scrollBy({ left: stepWidth(), behavior: "smooth" })
      );
  }

  // ---------- Lightbox ----------
  const lightbox = document.querySelector<HTMLElement>("#team-lightbox");
  const els = {
    photo: document.querySelector<HTMLImageElement>("#tl-photo"),
    name: document.querySelector<HTMLElement>("#tl-name"),
    role: document.querySelector<HTMLElement>("#tl-role"),
    bio: document.querySelector<HTMLElement>("#tl-bio"),
    email: document.querySelector<HTMLAnchorElement>("#tl-email"),
  };
  let lastTrigger: HTMLElement | null = null;

  function open(btn: HTMLElement) {
    if (!lightbox) return;
    lastTrigger = btn;
    const d = btn.dataset;
    if (els.photo) {
      els.photo.src = d.photo || "";
      els.photo.alt = d.name || "";
    }
    if (els.name) els.name.textContent = d.name || "";
    if (els.role) els.role.textContent = d.role || "";
    if (els.bio) els.bio.textContent = d.bio || "";
    if (els.email) {
      els.email.textContent = d.email || "";
      els.email.href = "mailto:" + (d.email || "");
    }
    lightbox.hidden = false;
    void lightbox.offsetWidth;
    lightbox.classList.add("is-open");
    document.body.style.overflow = "hidden";
    lightbox.querySelector<HTMLButtonElement>(".team-lightbox-close")?.focus();
  }
  function close() {
    if (!lightbox) return;
    lightbox.classList.remove("is-open");
    document.body.style.overflow = "";
    const onEnd = () => {
      lightbox.hidden = true;
      lightbox.removeEventListener("transitionend", onEnd);
    };
    lightbox.addEventListener("transitionend", onEnd);
    lastTrigger?.focus();
  }

  // Nach dem Klonen anhängen, damit auch die Klone die Lightbox öffnen
  document.querySelectorAll<HTMLElement>("[data-team-open]").forEach((btn) =>
    btn.addEventListener("click", () => open(btn))
  );
  document.querySelectorAll<HTMLElement>("[data-team-close]").forEach((el) =>
    el.addEventListener("click", close)
  );
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightbox && !lightbox.hidden) close();
  });
</script>
