---
// Schwebender, sticky Kontakt-Button "Schriib eus" – auf allen Seiten sichtbar.
// Verlinkt auf die Kontaktseite (alternativ mailto:info@uftritt.ch?subject=Kafidate).
const { href = "/kontakt" } = Astro.props;
---

<a class="floating-cta" href={href} aria-label="Schriib eus – zum Kontakt">
  <img src="/img/schriib-eus.png" alt="Schriib eus" width="132" height="132" />
</a>

<style>
  .floating-cta {
    position: fixed;
    right: clamp(1rem, 3vw, 2.5rem);
    bottom: clamp(1rem, 3vw, 2.5rem);
    z-index: 90;
    width: clamp(92px, 11vw, 132px);
    aspect-ratio: 1;
  }
  .floating-cta img {
    width: 100%;
    height: 100%;
    transform-origin: center;
    transition: transform 0.6s var(--ease);
  }
  /* Skalierung + Drehung auf dem Bild – sonst überschreibt die float-Animation des
     Wrappers das transform beim Hover. */
  .floating-cta:hover img {
    transform: scale(1.15) rotate(-20deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-cta {
      animation: none;
    }
    .floating-cta img {
      transition: none;
    }
    .floating-cta:hover img {
      transform: none;
    }
  }
</style>
