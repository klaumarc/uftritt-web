---
const siteNav = [
  { label: "Über Uftritt", href: "/agentur" },
  { label: "Angebot", href: "/angebot" },
  { label: "Projekte", href: "/projekte" },
  { label: "Partner", href: "/partner" },
  { label: "Kontakt", href: "/kontakt" },
  { label: "News", href: "/aktuell" },
];

const social = [
  { key: "linkedin", label: "LinkedIn", href: "https://www.linkedin.com/company/uftritt-gmbh/" },
  { key: "instagram", label: "Instagram", href: "https://www.instagram.com/uftritt/" },
  { key: "facebook", label: "Facebook", href: "https://www.facebook.com/profile.php?id=61551877650400" },
  { key: "youtube", label: "YouTube", href: "https://www.youtube.com/@UftrittGmbH" },
];

const legal = [
  { label: "Datenschutz", href: "/datenschutz" },
  { label: "Impressum", href: "/impressum" },
  { label: "AGB", href: "/agb" },
];
---

<footer class="site-footer">
  <div class="container footer-top">
    <div class="footer-brand">
      <a href="/" aria-label="Uftritt Startseite">
        <img src="/logo/uftritt-weiss.svg" alt="Uftritt" width="150" height="48" />
      </a>
      <p>Agentur für Kommunikation</p>
      <ul class="footer-social" aria-label="Social Media">
        {
          social.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class={`fs--${s.key}`}>
                <span class="fs-ico"></span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <nav class="footer-nav" aria-label="Seiten">
      <span class="footer-col-title">Seiten</span>
      <ul>
        {siteNav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-contact">
      <span class="footer-col-title">Kontakt</span>
      <address>
        Uftritt GmbH<br />
        Frauwisstrasse 9<br />
        8493 Saland
      </address>
      <a href="tel:+41445002955">044 500 29 55</a>
      <a href="mailto:info@uftritt.ch">info@uftritt.ch</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <nav class="footer-legal" aria-label="Rechtliches">
        {legal.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-blue);
    color: #fff;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    padding-block: clamp(2.5rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 2.25rem);
  }
  .footer-brand img {
    height: 46px;
    width: auto;
  }
  .footer-brand p {
    margin: 1rem 0 1.5rem;
    color: #fff;
  }

  /* Social: nur Icon (kein Kreis), weiss → bei Hover gelb */
  .footer-social {
    display: flex;
    gap: 0.5rem;
  }
  .footer-social a {
    display: grid;
    place-items: center;
    min-width: 40px;
    min-height: 40px;
    transition: transform 0.4s var(--ease);
  }
  .footer-social a:hover {
    transform: translateY(-2px);
  }
  .fs-ico {
    display: block;
    background-color: #fff;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
    transition: background-color 0.4s var(--ease);
  }
  .footer-social a:hover .fs-ico {
    background-color: var(--color-yellow);
  }
  .fs--linkedin .fs-ico {
    width: 20px; height: 20px;
    -webkit-mask-image: url("/icons/linkedin-icon.svg");
    mask-image: url("/icons/linkedin-icon.svg");
  }
  .fs--instagram .fs-ico {
    width: 20px; height: 20px;
    -webkit-mask-image: url("/icons/instagram-icon.svg");
    mask-image: url("/icons/instagram-icon.svg");
  }
  .fs--facebook .fs-ico {
    width: 11px; height: 21px;
    -webkit-mask-image: url("/icons/facebook-icon.svg");
    mask-image: url("/icons/facebook-icon.svg");
  }
  .fs--youtube .fs-ico {
    width: 24px; height: 18px;
    -webkit-mask-image: url("/icons/youtube-icon.svg");
    mask-image: url("/icons/youtube-icon.svg");
  }

  .footer-col-title {
    display: block;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #fff;
  }
  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.35;
  }
  .footer-nav a,
  .footer-contact a {
    color: #fff;
    transition: color 0.4s var(--ease);
  }
  .footer-nav a:hover,
  .footer-contact a:hover,
  .footer-legal a:hover {
    color: var(--color-yellow);
  }
  .footer-contact address {
    font-style: normal;
    line-height: 1.6;
    color: #fff;
    margin-bottom: 1rem;
  }
  .footer-contact a {
    display: block;
  }

  /* Rechtliches ganz unten */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }
  .footer-bottom-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-block: 1.1rem;
    font-size: 0.9rem;
  }
  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    color: #fff;
    transition: color 0.4s var(--ease);
  }

  @media (max-width: 780px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }
</style>
