---
// Prozess-Schritte als Auto-Fokus-Karussell.
// Ein Schritt ist reihum im Fokus (grösser + voll deckend), die anderen dezent
// zurückgenommen. Läuft automatisch im Loop; Hover fokussiert den Schritt unter
// der Maus (Loop pausiert), ohne Hover läuft er weiter. Genutzt auf /angebot und
// allen Dienstleistungs-Unterseiten.
interface Step {
  icon?: string;
  t: string;
  d: string;
}
interface Props {
  steps: Step[];
  showIcons?: boolean;
}
const { steps, showIcons = false } = Astro.props;
---

<ol class="steps" data-reveal>
  {
    steps.map((s, i) => (
      <li class="step">
        {showIcons && s.icon && (
          <img class="step-icon" src={s.icon} alt="" width="48" height="48" />
        )}
        <span class="step-no">{String(i + 1).padStart(2, "0")}</span>
        <h3>{s.t}</h3>
        <p>{s.d}</p>
      </li>
    ))
  }
</ol>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(1rem, 2vw, 1.75rem);
  }
  .step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-bottom: 3px solid var(--color-blue);
    padding-bottom: 1.25rem;
    /* Auto-Fokus-Karussell: nicht-aktive Schritte dezent zurückgenommen */
    opacity: 0.4;
    transform: scale(0.95);
    transform-origin: bottom center;
    transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);
  }
  .step.is-active {
    opacity: 1;
    transform: scale(1.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .step {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  .step-icon {
    width: 72px;
    height: 72px;
    margin-bottom: 0.9rem;
  }
  .step-no {
    display: block;
    font-weight: 900;
    font-size: 1.6rem;
    color: var(--color-blue);
    margin-bottom: 0.5rem;
  }
  .step h3 {
    font-size: 1.15rem;
    color: var(--color-blue);
    margin-bottom: 0.4rem;
  }
  .step p {
    color: var(--color-blue);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Alle Prozess-Listen auf der Seite als Auto-Fokus-Karussell initialisieren.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  document.querySelectorAll<HTMLOListElement>(".steps").forEach((list) => {
    const steps = Array.from(list.querySelectorAll<HTMLElement>(".step"));
    if (!steps.length) return;
    let idx = 0;
    let timer: number | undefined;

    const focus = (i: number) => {
      idx = (i + steps.length) % steps.length;
      steps.forEach((s, n) => s.classList.toggle("is-active", n === idx));
    };
    const stop = () => {
      if (timer) {
        clearInterval(timer);
        timer = undefined;
      }
    };
    const start = () => {
      if (reduce || timer) return;
      timer = window.setInterval(() => focus(idx + 1), 2600);
    };

    focus(0);
    // Hover: Fokus folgt der Maus (Loop pausiert)
    steps.forEach((s, n) =>
      s.addEventListener("mouseenter", () => {
        stop();
        focus(n);
      })
    );
    // Klick fokussiert ebenfalls (Touch/Tastatur)
    steps.forEach((s, n) => s.addEventListener("click", () => focus(n)));
    list.addEventListener("mouseenter", stop);
    list.addEventListener("mouseleave", start);

    if (!reduce && "IntersectionObserver" in window) {
      new IntersectionObserver(
        (entries) => entries.forEach((e) => (e.isIntersecting ? start() : stop())),
        { threshold: 0.3 }
      ).observe(list);
    } else {
      start();
    }
  });
</script>
