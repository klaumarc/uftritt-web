---
import Lottie from "./Lottie.astro";

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  compact?: boolean;
  light?: boolean;
  lottie?: string;
  lottieLabel?: string;
}
const { eyebrow, title, lead, compact = false, light = false, lottie, lottieLabel } = Astro.props;
---

<section
  class:list={[
    "page-hero",
    {
      "section--yellow": !light,
      "page-hero--compact": compact,
      "page-hero--has-lottie": lottie,
    },
  ]}
>
  <div class="container page-hero-inner">
    <div class="page-hero-text">
      {eyebrow && <span class="eyebrow" data-reveal>{eyebrow}</span>}
      <h1 data-reveal>{title}</h1>
      {lead && <p class="page-hero-lead" data-reveal>{lead}</p>}
      <slot name="hero-extra" />
    </div>
  </div>

  {
    lottie && (
      <div class="page-hero-lottie" data-lottie-trigger aria-hidden="true">
        <Lottie src={lottie} hover={true} ariaLabel={lottieLabel} />
      </div>
    )
  }
</section>

<style>
  /* Kompakter Header als Standard */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(1.25rem, 3vw, 2rem);
  }
  /* Variante mit Json rechts: Text links, Lottie gross am rechten Rand */
  .page-hero--has-lottie {
    display: flex;
    align-items: center;
    min-height: calc(100svh - 76px); /* Vollbild-Hero (minus Sticky-Header) */
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .page-hero-inner {
    width: 100%;
    position: relative;
    z-index: 1;
  }
  .page-hero-text {
    max-width: 620px;
  }
  .page-hero .eyebrow {
    display: block;
    margin-bottom: 0.5rem;
  }
  /* Kompakter Header (ohne Json): moderatere Titelgrösse, damit auch lange
     Einzelwörter wie "Applikationsentwicklung" nicht auf 3 Zeilen umbrechen.
     Die Vollbild-Header (mit Json) behalten die grosse Schrift. */
  .page-hero:not(.page-hero--has-lottie) h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    text-wrap: balance;
  }
  .page-hero-lead {
    max-width: 640px;
    font-size: clamp(1.3rem, 2.1vw, 1.9rem);
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-blue);
    margin-top: 1.5rem;
  }

  /* Json rechts – mit Abstand zum Rand, nicht angeschnitten */
  .page-hero-lottie {
    position: absolute;
    top: 50%;
    right: clamp(1.5rem, 5vw, 4rem);
    transform: translateY(-50%);
    width: min(46vw, 560px);
    height: min(46vw, 560px);
    z-index: 2; /* über dem Text-Layer, damit der Hover zuverlässig das JSON trifft */
    cursor: pointer;
  }

  @media (max-width: 980px) {
    .page-hero--has-lottie {
      display: block;
      min-height: auto;
    }
    .page-hero-lottie {
      position: static;
      transform: none;
      width: min(70vw, 340px);
      height: min(70vw, 340px);
      margin: 1.75rem 0 0 auto;
    }
  }
</style>
