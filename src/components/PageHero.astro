---
import Lottie from "./Lottie.astro";

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  compact?: boolean;
  light?: boolean;
  lottie?: string;
  lottieLabel?: string;
}
const { eyebrow, title, lead, compact = false, light = false, lottie, lottieLabel } = Astro.props;
---

<section
  class:list={[
    "page-hero",
    {
      "section--yellow": !light,
      "page-hero--compact": compact,
      "page-hero--has-lottie": lottie,
    },
  ]}
>
  <div class="container page-hero-inner">
    <div class="page-hero-text">
      {eyebrow && <span class="eyebrow" data-reveal>{eyebrow}</span>}
      <h1 data-reveal>{title}</h1>
      {lead && <p class="page-hero-lead" data-reveal>{lead}</p>}
      <slot name="hero-extra" />
    </div>
    {
      lottie && (
        <div class="page-hero-lottie" data-lottie-trigger aria-hidden="true">
          <Lottie src={lottie} hover={true} ariaLabel={lottieLabel} />
        </div>
      )
    }
  </div>
</section>

<style>
  /* Kompakter Header als Standard */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(1.25rem, 3vw, 2rem);
  }
  /* Variante mit Json rechts: Text links, Lottie gross am rechten Rand */
  .page-hero--has-lottie {
    display: flex;
    align-items: center;
    min-height: calc(100svh - 76px); /* Vollbild-Hero (minus Sticky-Header) */
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .page-hero-inner {
    width: 100%;
    position: relative;
    z-index: 1;
  }
  .page-hero-text {
    max-width: 620px;
  }
  /* Mit Lottie: Text = linke Spalte, füllt den Platz bis zum Lottie (nicht mehr
     in schmaler Spalte links festgenagelt) – Revision Jeffrey. */
  .page-hero--has-lottie .page-hero-text {
    flex: 1 1 auto;
    /* explizit den 620px-Basis-Deckel aufheben: Text füllt die linke Spalte,
       H1 läuft auf breiten Screens aus ("Webdesign und" kommt hoch).
       Lead bleibt via .page-hero-lead schmal. */
    max-width: none;
  }
  .page-hero .eyebrow {
    display: block;
    margin-bottom: 0.5rem;
  }
  /* Kompakter Header (ohne Json): gleiche grosse Titel-Schrift wie die
     Vollbild-Header (stringent), aber mehr Spaltenbreite – so passt auch ein
     langes Wort wie "Applikationsentwicklung" auf eine Zeile statt auf drei. */
  .page-hero:not(.page-hero--has-lottie) .page-hero-text {
    max-width: none;
  }
  .page-hero:not(.page-hero--has-lottie) h1 {
    text-wrap: balance;
  }
  .page-hero-lead {
    max-width: 640px;
    font-size: clamp(1.3rem, 2.1vw, 1.9rem);
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-blue);
    margin-top: 1.5rem;
  }

  /* Json als rechte Spalte INNERHALB des zentrierten Containers (nicht am
     Bildschirmrand) – so ist der Hero ausbalanciert statt links gequetscht. */
  .page-hero--has-lottie .page-hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .page-hero-lottie {
    flex: none;
    width: min(38vw, 460px);
    aspect-ratio: 1;
    z-index: 2; /* über dem Text-Layer, damit der Hover zuverlässig das JSON trifft */
    cursor: pointer;
  }

  @media (max-width: 980px) {
    .page-hero--has-lottie {
      display: block;
      min-height: auto;
    }
    .page-hero--has-lottie .page-hero-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.75rem;
    }
    .page-hero-lottie {
      width: min(70vw, 340px);
      margin-left: auto;
    }
  }
</style>
