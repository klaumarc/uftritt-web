---
import Layout from "../../layouts/Layout.astro";
import ProcessSteps from "../../components/ProcessSteps.astro";
import ServiceMarquee from "../../components/ServiceMarquee.astro";
import RefStrip from "../../components/RefStrip.astro";
import PageHero from "../../components/PageHero.astro";
import Button from "../../components/Button.astro";
import { projects } from "../../data/projects";

const bySlug = (slug: string) => projects.find((p) => p.slug === slug)!;
const portfolio = ["aweso", "aas-freight", "youngstars"].map(bySlug);

const blocks = [
  {
    title: "Strategie und Planung",
    text: [
      "Wer soll wann und womit erreicht werden? Gemeinsam definieren wir Ziele, Zielgruppen und einen Massnahmenplan, der zu deinem Budget passt.",
      "So weisst du von Anfang an, wohin die Reise geht – und warum.",
    ],
  },
  {
    title: "Content und Kampagnen",
    text: [
      "Von Social Media über Newsletter bis zur Printkampagne: Wir produzieren Inhalte, die zusammenpassen und deine Botschaft konsequent transportieren.",
      "Ein Auftritt aus einer Hand – über alle Kanäle hinweg stimmig.",
    ],
  },
  {
    title: "Begleitung und Auswertung",
    text: [
      "Wir bleiben dran, behalten die Resultate im Blick und justieren laufend nach.",
      "So wirkt dein Marketing nicht nur einmal, sondern wächst mit dir mit.",
    ],
  },
];

const steps = [
  { icon: "/img/icons/zuhoeren-icon.svg", t: "Zuhören und verstehen", d: "Was willst du erreichen, wen willst du ansprechen? Wir nehmen deine Ziele auf." },
  { icon: "/img/icons/analyse-icon.svg", t: "Strategie", d: "Wir analysieren Markt und Zielgruppe und entwickeln einen klaren Massnahmenplan." },
  { icon: "/img/icons/brainstorm-icon.svg", t: "Konzept und Content", d: "Wir entwickeln Ideen und produzieren die passenden Inhalte für deine Kanäle." },
  { icon: "/img/icons/austauschen-icon.svg", t: "Umsetzung", d: "Wir bringen die Kampagne live – koordiniert über alle Kanäle hinweg." },
  { icon: "/img/icons/abheben-icon.svg", t: "Auswerten und Optimieren", d: "Wir messen, lernen und justieren nach, damit dein Marketing besser und besser wird." },
];
---

<Layout title="Marketingbegleitung – Uftritt" description="Strategisch geplant, kreativ umgesetzt und messbar – wir begleiten dein Marketing über Kampagnen und Kanäle hinweg.">
  <PageHero
    eyebrow="Angebot"
    title="Marketingbegleitung"
    lead="Gutes Marketing ist kein Einzelschuss, sondern ein roter Faden. Wir begleiten dich über Kampagnen und Kanäle hinweg – strategisch geplant, kreativ umgesetzt und messbar."
    lottie="/lottie/marketingbegleitung.json"
    lottieLabel="Marketingbegleitung"
  />

  <section class="section">
    <div class="container lp-blocks">
      {
        blocks.map((b) => (
          <article class="lp-block" data-reveal>
            <h2>{b.title}</h2>
            <div class="lp-text">{b.text.map((p) => <p>{p}</p>)}</div>
          </article>
        ))
      }
    </div>
  </section>

  {/* Das gestalten wir für dich */}
  <ServiceMarquee
    title="Von der Strategie bis zur Kampagne"
    terms={["Marketingstrategie", "Kampagnen", "Social Media", "Content-Planung", "Redaktionsplan", "Newsletter", "Google Ads", "SEO", "Community Management", "Employer Branding", "Events", "Messeauftritte", "Analytics", "Beratung", "Storytelling"]}
  />

  {/* Prozess */}
  <section class="section section--yellow">
    <div class="container">
      <header class="section-head" data-reveal>
        <span class="eyebrow">Unser Marketing-Prozess</span>
        <h2>Persönlich. Kreativ. Partnerschaftlich.</h2>
      </header>
      <ProcessSteps steps={steps} />
    </div>
  </section>


  {/* Referenzen */}
  <RefStrip title="Kampagnen aus unserem Portfolio" projects={portfolio} />

  <section class="section section--yellow">
    <div class="container lp-cta" data-reveal>
      <h2>Bereit, sichtbar zu werden?</h2>
      <Button href="/kontakt" variant="blue">Schriib eus</Button>
    </div>
  </section>
</Layout>

<style>
  .lp-blocks { display: flex; flex-direction: column; gap: clamp(2.5rem, 5vw, 4.5rem); }
  .lp-block { display: grid; grid-template-columns: 1fr 2fr; gap: clamp(1rem, 3vw, 3rem); align-items: start; }
  .lp-block h2 { position: sticky; top: 100px; }
  .lp-text p { color: var(--color-blue); font-size: 1.1rem; line-height: 1.7; margin-bottom: 1rem; }

  .section-head { margin-bottom: clamp(2rem, 4vw, 3rem); }

  .steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: clamp(1rem, 2vw, 1.75rem); }
  .step { display: flex; flex-direction: column; align-items: flex-start; }
  .step-icon { width: 64px; height: 64px; margin-bottom: 0.9rem; }
  .step-no { display: block; width: 100%; border-bottom: 3px solid var(--color-blue); padding-bottom: 0.6rem; font-weight: 900; font-size: 1.6rem; color: var(--color-blue); margin-bottom: 0.5rem; }
  .step h3 { font-size: 1.1rem; color: var(--color-blue); margin-bottom: 0.4rem; }
  .step p { color: var(--color-blue); font-size: 0.95rem; line-height: 1.55; }

  .portfolio { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.5rem, 1.2vw, 0.9rem); }
  .ref-card { position: relative; display: block; aspect-ratio: 4 / 3; overflow: hidden; background: #eef2f7; }
  .ref-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.85s var(--ease); }
  .ref-card:hover .ref-img, .ref-card:focus-visible .ref-img { transform: scale(1.05); }
  .ref-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.35rem; padding: 1.5rem;
    text-align: center; background: rgba(1, 64, 128, 0.82); color: #fff;
    opacity: 0; transition: opacity 0.5s var(--ease);
  }
  .ref-card:hover .ref-overlay, .ref-card:focus-visible .ref-overlay { opacity: 1; }
  .ref-cat { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.85; }
  .ref-title { font-size: clamp(1.1rem, 1.8vw, 1.5rem); font-weight: 700; line-height: 1.15; }
  .center-cta { margin-top: clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  .lp-cta { display: flex; flex-direction: column; align-items: flex-start; gap: 1.25rem; }

  @media (max-width: 900px) {
    .steps { grid-template-columns: repeat(2, 1fr); }
    .portfolio { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .lp-block { grid-template-columns: 1fr; }
    .lp-block h2 { position: static; }
  }
  @media (max-width: 520px) {
    .steps { grid-template-columns: 1fr; }
    .portfolio { grid-template-columns: 1fr; }
  }
</style>
