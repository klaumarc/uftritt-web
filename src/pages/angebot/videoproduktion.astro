---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Button from "../../components/Button.astro";
import { projects } from "../../data/projects";

const portfolio = projects
  .filter((p) => p.categories.includes("Videoproduktion"))
  .slice(0, 6);

const blocks = [
  {
    title: "Imagefilm",
    text: [
      "Mit einem Video erhältst du die Möglichkeit, dein Unternehmen oder dein Projekt auf vielschichtige und authentische Weise zu präsentieren. Ein Imagefilm vermittelt interessante Einblicke in die Tätigkeiten, die Motivation und die Menschen dahinter.",
      "Wir entwickeln mit dir das Storyboard für deinen Film und setzen diesen mit professionellen Mitteln um.",
    ],
  },
  {
    title: "Produktfilm",
    text: [
      "Du möchtest dein Produkt deinem Publikum im besten Licht vorstellen? Mit bewegten Bildern werden dessen Stärken noch greifbarer und durch die gezielte Einbindung von Nutzererlebnissen entsteht ein positives Gefühl bei der Zielperson.",
      "Wir unterstützen dich dabei, dein Produkt in Szene zu setzen und ihm eine gebührende Plattform zu bieten.",
    ],
  },
  {
    title: "Video-Podcast",
    text: [
      "Bring dein Know-how oder spannende Gäste direkt vor die Kamera. Wir produzieren deinen Video-Podcast – live oder aufgezeichnet, mehrsprachig, mit professionellem Sound und authentischem Look.",
      "Perfekt für Social Media, Website oder interne Kommunikation: So bleibt deine Message garantiert im Kopf.",
    ],
  },
  {
    title: "Eventfilm",
    text: [
      "Erlebe deinen Event, deine Messe oder Präsentation immer wieder aufs Neue – mit einem dynamisch geschnittenen Eventfilm von Uftritt. Wir fangen Emotionen, Highlights und echte Momente ein.",
      "Ob Liveaufnahmen, Interviews oder Clips für Social Media: Dein Anlass bleibt unvergesslich sichtbar und macht richtig Eindruck.",
    ],
  },
  {
    title: "Social Media Content",
    text: [
      "Social Media ist für viele Unternehmen unverzichtbar, um bei der Kundschaft präsent zu sein und zu bleiben. Mit kurzen Clips und einem Storykonzept gibst du auf lockere Weise Einblick in dein Unternehmen oder wirbst per Ads gezielt für dich.",
      "Mit Know-how und den richtigen Mitteln erreichen wir gemeinsam deine Zielgruppe.",
    ],
  },
];

const steps = [
  { icon: "/img/icons/zuhoeren-icon.svg", t: "Kennenlernen", d: "Wir schlagen kein Standardkonzept vor, sondern hören erstmal zu: Was willst du zeigen, wen willst du erreichen, und wie viel Action soll ins Bild? Dein Thema, deine Vision, unsere Leidenschaft." },
  { icon: "/img/icons/brainstorm-icon.svg", t: "Konzeption", d: "Gemeinsam entwickeln wir erste Ideen und Moodboards. Du bekommst ein transparentes Angebot." },
  { icon: "/img/icons/analyse-icon.svg", t: "Planung", d: "Wir planen alles vor: Drehorte, Termine, Technik, Sprecher, Musik etc. Du bist immer auf dem Laufenden – ohne Planungsstress für dich." },
  { icon: "/img/icons/video-icon.svg", t: "Drehtag(e)", d: "Jetzt wird produziert: Wir setzen dein Video professionell um – live vor Ort, mit Drohne, O-Tönen, Produkt- oder Eventaufnahmen. Du kannst mitwirken, dabei sein und auf Wunsch Korrekturen direkt vor Ort einbringen." },
  { icon: "/img/icons/austauschen-icon.svg", t: "Rohschnitt", d: "Nach dem Dreh erhältst du den ersten Rohschnitt – nun kommt deine Sicht ins Spiel. Änderungswünsche und Feinjustierung werden nach deinem Feedback umgesetzt. In der Regel eine Feedbackrunde, auf Wunsch auch zwei." },
  { icon: "/img/icons/grafikdesign-icon.svg", t: "Feinschliff und Endfertigung", d: "Wir finalisieren den Schnitt, machen die Farbkorrektur, bauen Musik, Sprecher:in und Grafiken ein. Jetzt bekommst du die fertige Version in allen gängigen Formaten." },
  { icon: "/img/icons/abheben-icon.svg", t: "Unterstützung bei Veröffentlichung", d: "Optional helfen wir bei Upload, Einbindung und Marketing deines Videos." },
];

const faq = [
  { q: "Welche Arten von Videos produziert ihr?", a: "Von Imagefilm und Social-Media-Clip bis Recruiting-Video, Eventfilm oder Produktvideo – (fast) alles ist möglich. Dein Thema, dein Ziel, unser Film: immer massgeschneidert für dich und dein Unternehmen." },
  { q: "Warum lohnt sich ein professionelles Video für mein Unternehmen?", a: "Bewegtbild erregt Aufmerksamkeit, erklärt komplexe Themen verständlich und schafft sofort Nähe zur Zielgruppe. Im Zürcher Oberland und darüber hinaus setzt du dich so klar von deiner Konkurrenz ab." },
  { q: "Wie läuft die Zusammenarbeit bei einer Videoproduktion mit Uftritt ab?", a: "Zuerst sprechen wir über deine Wünsche und Ziele. Wir übernehmen Storyboard, Dreh, Schnitt und alles Drumherum – du bekommst regelmässige Einblicke und bist immer Teil des Prozesses." },
  { q: "Wo finden die Dreharbeiten statt?", a: "Drinnen, draussen, bei dir im Unternehmen, im Studio oder an besonderen Locations – du bestimmst den Rahmen, wir kümmern uns um Technik und Atmosphäre." },
  { q: "Was kostet eine Videoproduktion und wie lange dauert's?", a: "Dein Video ist so individuell wie dein Auftritt. Nach unserem Erstgespräch erhältst du ein transparentes Angebot inklusive aller Leistungen. Die Länge des Projekts hängt vom Umfang und deinen Wünschen ab, meistens geht's in wenigen Wochen von der Idee zum fertigen Film." },
  { q: "Welche Rolle spiele ich als Kund:in im Prozess?", a: "Du musst kein Filmprofi sein – Ideen, Wünsche oder ein grobes Ziel reichen völlig. Wir begleiten und beraten dich Schritt für Schritt und holen das Beste aus deiner Story heraus." },
  { q: "In welchem Format erhalte ich mein Video?", a: "Du erhältst dein Video in allen gängigen Formaten – perfekt vorbereitet für Website, Social Media, Messe, Smartphone oder Präsentation." },
  { q: "Kann ich professionelle Sprecheraufnahmen buchen?", a: "Ja – auf Wunsch vermitteln wir professionelle Sprecher:innen in verschiedenen Sprachen und Stimmlagen oder nehmen O-Töne direkt am Set auf. So bekommt dein Video genau die Stimme, die zu deiner Marke passt." },
  { q: "Sind Drohnenaufnahmen, Fahrzeug- oder Unterwasseraufnahmen möglich?", a: "Ja – unabhängig von der Aufnahmeperspektive. Wir bieten spektakuläre Drohnenflüge (auch FPV!), dynamische Fahrzeug-Shots und beeindruckende Unterwasseraufnahmen. Für jede Anforderung und (fast) jede Location haben wir das passende Equipment." },
  { q: "Brauche ich eine Einverständniserklärung bei Videoaufnahmen?", a: "Ja, sobald Personen im Video identifizierbar sind, ist eine schriftliche Einwilligung nötig – sowohl für die Aufnahme als auch für jede geplante Veröffentlichung (z. B. Website, Social Media, Werbung)." },
  { q: "Welche Rechte habe ich am fertigen Video?", a: "Du erhältst die Nutzungsrechte für dein Projekt – wie und wo du das Video einsetzt (Website, Social Media, Events), legen wir gemeinsam fest. Erweiterte Rechte oder ein Buyout sind jederzeit möglich – sprich uns gern an, falls du dein Video universell nutzen möchtest." },
];
---

<Layout title="Videoproduktion – Uftritt" description="Imagefilm, Produktfilm, Video-Podcast, Eventfilm und Social Media Content – wir lassen deine Botschaft lebendig werden.">
  <PageHero
    eyebrow="Angebot"
    title="Videoproduktion"
    lead="Gut erzählte Geschichten rufen Emotionen hervor und sind heute wichtiger denn je, um Aufmerksamkeit zu generieren. Mit der videografischen Umsetzung werden Botschaften lebendig und hinterlassen einen bleibenden Eindruck."
    lottie="/lottie/videoproduktion.json"
    lottieLabel="Videoproduktion"
  />

  <section class="section">
    <div class="container lp-blocks">
      {
        blocks.map((b) => (
          <article class="lp-block" data-reveal>
            <h2>{b.title}</h2>
            <div class="lp-text">
              {b.text.map((p) => <p>{p}</p>)}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  {/* Prozess */}
  <section class="section section--yellow">
    <div class="container">
      <header class="section-head" data-reveal>
        <span class="eyebrow">Unser Video-Prozess</span>
        <h2>Persönlich. Kreativ. Partnerschaftlich.</h2>
      </header>
      <ol class="steps">
        {
          steps.map((s, i) => (
            <li class="step" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <span class="step-no">{String(i + 1).padStart(2, "0")}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* FAQ */}
  <section class="section">
    <div class="container faq-wrap">
      <header class="section-head" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2>Die wichtigsten Fragen, ehrlich beantwortet</h2>
      </header>
      <div class="faq" data-reveal>
        {
          faq.map((f, i) => (
            <details class="faq-item" name="faq" open={i === 0}>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  {/* Portfolio */}
  <section class="section section--soft">
    <div class="container">
      <header class="section-head" data-reveal>
        <span class="eyebrow">Referenzen</span>
        <h2>Videoprojekte aus unserem Portfolio</h2>
      </header>
      <div class="portfolio">
        {
          portfolio.map((p) => (
            <a href={`/projekte/${p.slug}`} class="ref-card" aria-label={p.title} data-reveal>
              <img class="ref-img" src={p.image} alt={p.title} loading="lazy" />
              <span class="ref-overlay">
                <span class="ref-cat">{p.categories.join(" · ")}</span>
                <span class="ref-title">{p.title}</span>
              </span>
            </a>
          ))
        }
      </div>
      <div class="center-cta" data-reveal>
        <Button href="/projekte" variant="blue">Alle Projekte ansehen</Button>
      </div>
    </div>
  </section>

  <section class="section section--yellow">
    <div class="container lp-cta" data-reveal>
      <h2>Lass uns deine Geschichte erzählen</h2>
      <Button href="/kontakt" variant="blue">Schriib eus</Button>
    </div>
  </section>
</Layout>

<style>
  .lp-blocks {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4.5rem);
  }
  .lp-block {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(1rem, 3vw, 3rem);
    align-items: start;
  }
  .lp-block h2 {
    position: sticky;
    top: 100px;
  }
  .lp-text p {
    color: var(--color-blue);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .section-head { margin-bottom: clamp(2rem, 4vw, 3rem); }

  .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: clamp(1rem, 2vw, 1.75rem); }
  .step { display: flex; flex-direction: column; align-items: flex-start; }
  .step-icon { width: 64px; height: 64px; margin-bottom: 0.9rem; }
  .step-no { display: block; width: 100%; border-bottom: 3px solid var(--color-blue); padding-bottom: 0.6rem; font-weight: 900; font-size: 1.6rem; color: var(--color-blue); margin-bottom: 0.5rem; }
  .step h3 { font-size: 1.1rem; color: var(--color-blue); margin-bottom: 0.4rem; }
  .step p { color: var(--color-blue); font-size: 0.95rem; line-height: 1.55; }

  /* Portfolio-Kacheln – Hover wie auf der Startseite */
  .portfolio { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.5rem, 1.2vw, 0.9rem); }
  .ref-card { position: relative; display: block; aspect-ratio: 4 / 3; overflow: hidden; background: #eef2f7; }
  .ref-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.85s var(--ease); }
  .ref-card:hover .ref-img, .ref-card:focus-visible .ref-img { transform: scale(1.05); }
  .ref-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.35rem; padding: 1.5rem;
    text-align: center; background: rgba(1, 64, 128, 0.82); color: #fff;
    opacity: 0; transition: opacity 0.5s var(--ease);
  }
  .ref-card:hover .ref-overlay, .ref-card:focus-visible .ref-overlay { opacity: 1; }
  .ref-cat { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.85; }
  .ref-title { font-size: clamp(1.1rem, 1.8vw, 1.5rem); font-weight: 700; line-height: 1.15; }
  .center-cta { margin-top: clamp(2.5rem, 5vw, 3.5rem); text-align: center; }

  .faq-wrap { max-width: 860px; }
  .faq-item { border-bottom: 1px solid rgba(1, 64, 128, 0.2); }
  .faq-item summary {
    cursor: pointer; list-style: none; padding: 1.1rem 0;
    font-weight: 700; color: var(--color-blue); font-size: 1.15rem;
    display: flex; justify-content: space-between; gap: 1rem;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; font-weight: 700; transition: transform 0.3s var(--ease); }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { color: var(--color-blue); line-height: 1.7; padding-bottom: 1.1rem; max-width: 70ch; }

  .lp-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .portfolio { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .lp-block { grid-template-columns: 1fr; }
    .lp-block h2 { position: static; }
  }
  @media (max-width: 520px) {
    .portfolio { grid-template-columns: 1fr; }
  }
</style>
