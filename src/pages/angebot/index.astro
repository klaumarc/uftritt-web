---
import Layout from "../../layouts/Layout.astro";
import SubHero from "../../components/SubHero.astro";
import Lottie from "../../components/Lottie.astro";
import Button from "../../components/Button.astro";
import { projects } from "../../data/projects";

const bySlug = (slug: string) => projects.find((p) => p.slug === slug)!;

const services = [
  {
    lottie: "/lottie/grafikdesign.json",
    title: "Grafikdesign",
    subtitle: "Corporate Design, Editorial Design, durchdacht",
    href: "/angebot/grafikdesign",
    refs: ["spinnereiplatz", "cva", "dtb-redesign"],
  },
  {
    lottie: "/lottie/webdesign.json",
    title: "Webdesign und Entwicklung",
    subtitle: "UI Design, Erlebnis, nutzerzentriert",
    href: "/angebot/webdesign",
    refs: ["ripa-immobilien", "regan", "seatalytics"],
  },
  {
    lottie: "/lottie/videoproduktion.json",
    title: "Videoproduktion",
    subtitle: "Storytelling, Emotionen, beeindruckend",
    href: "/angebot/videoproduktion",
    refs: ["aas-freight", "empower", "heusser-holzbau"],
  },
];

// Musterprojekte für die Vorschau unten (Mehrfach-Disziplinen)
const featured = ["100pro-openair-2024", "youngstars", "fahrschule-schweiz"].map(bySlug);

const steps = [
  { icon: "/img/icons/zuhoeren-icon.svg", t: "Zuhören und Verstehen", d: "Wir starten mit offenen Ohren: Was macht dich besonders? Welche Ziele verfolgst du? Wer soll angesprochen werden?" },
  { icon: "/img/icons/analyse-icon.svg", t: "Analysieren", d: "Wir schauen genau hin – Zielgruppe, Markt und Wettbewerb. Daraus entsteht ein massgeschneidertes Konzept." },
  { icon: "/img/icons/brainstorm-icon.svg", t: "Brainstormen", d: "Gemeinsam entwickeln wir Ideen, Richtungen und die passende kreative Lösung." },
  { icon: "/img/icons/austauschen-icon.svg", t: "Austauschen", d: "Enge Zusammenarbeit mit klaren Feedbackschlaufen – du gestaltest jederzeit mit." },
  { icon: "/img/icons/abheben-icon.svg", t: "Abheben und feiern", d: "Umsetzung, Liveschaltung – und gemeinsam den Erfolg feiern." },
];
---

<Layout title="Angebot – Uftritt" description="Corporate Design, Webdesign, Videoproduktion und mehr – wir machen uns mit dir auf den Weg zur durchdachten, wirkungsvollen Lösung.">
  <SubHero
    eyebrow="Angebot"
    title="Alles aus einer Hand"
    lead="Ob Corporate Design, Editorial Design, die Entwicklung einer neuen Website, ein aussagekräftiges Video oder das Gesamtpaket für deine Kommunikation – wir machen uns mit dir auf den Weg zur durchdachten und wirkungsvollen Lösung."
    lottie="/lottie/angebot-uebersicht.json"
    lottieLabel="Angebot"
  />

  <section class="section">
    <div class="container">
      {
        services.map((s) => (
          <div class="svc-block" data-reveal>
            <header class="svc-head" data-lottie-trigger>
              <div class="svc-icon">
                <Lottie src={s.lottie} hover={true} ariaLabel={s.title} />
              </div>
              <div class="svc-intro">
                <h2>{s.title}</h2>
                <p>{s.subtitle}</p>
              </div>
              <Button href={s.href} variant="text" class="svc-more">
                Mehr zu {s.title}
              </Button>
            </header>

            <div class="svc-refs">
              {s.refs.map((slug) => {
                const p = bySlug(slug);
                return (
                  <a href={`/projekte/${p.slug}`} class="ref-card" aria-label={p.title}>
                    <img class="ref-img" src={p.image} alt={p.title} loading="lazy" />
                    <span class="ref-overlay">
                      <span class="ref-cat">{p.categories.join(" · ")}</span>
                      <span class="ref-title">{p.title}</span>
                    </span>
                  </a>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section section--yellow">
    <div class="container">
      <header class="section-head" data-reveal>
        <span class="eyebrow">So gehen wir vor</span>
        <h2>Persönlich. Kreativ. Partnerschaftlich.</h2>
        <p class="lead-max">
          Die optimale Lösung für dein Projekt entsteht in einem zielgerichteten
          Prozess. Darum folgen wir grundsätzlich fünf einfachen Schritten.
        </p>
      </header>
      <ol class="steps">
        {
          steps.map((s, i) => (
            <li class="step" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <img class="step-icon" src={s.icon} alt="" width="48" height="48" />
              <span class="step-no">{String(i + 1).padStart(2, "0")}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-head" data-reveal>
        <h2>Überzeuge dich selbst von unserer Arbeit</h2>
      </header>
      <div class="ang-featured">
        {
          featured.map((p, i) => (
            <a href={`/projekte/${p.slug}`} class="ref-card" aria-label={p.title} data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <img class="ref-img" src={p.image} alt={p.title} loading="lazy" />
              <span class="ref-overlay">
                <span class="ref-cat">{p.categories.join(" · ")}</span>
                <span class="ref-title">{p.title}</span>
              </span>
            </a>
          ))
        }
      </div>
      <div class="ang-cta" data-reveal>
        <Button href="/projekte" variant="blue">Alli Projekt aluege</Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- Dienstleistung als Block mit Referenzen ---------- */
  .svc-block {
    padding-block: clamp(2rem, 4vw, 3.25rem);
    border-top: 1px solid #e7ecf3;
  }
  .svc-block:first-child {
    border-top: none;
    padding-top: 0;
  }
  .svc-head {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.5rem);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .svc-icon {
    width: clamp(88px, 9vw, 120px);
    height: clamp(88px, 9vw, 120px);
    flex: none;
  }
  .svc-intro {
    flex: 1;
  }
  .svc-intro h2 {
    color: var(--color-blue);
    margin-bottom: 0.15rem;
  }
  .svc-intro p {
    color: var(--color-blue);
  }
  .svc-more {
    flex: none;
    white-space: nowrap;
  }

  .svc-refs,
  .ang-featured {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.5rem, 1.2vw, 0.9rem);
  }
  .ang-featured {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
  }

  /* Referenz-Kacheln – Hover wie auf der Startseite (Bild-Zoom + blaues Overlay) */
  .ref-card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f1f4f8;
  }
  .ref-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.85s var(--ease);
  }
  .ref-card:hover .ref-img,
  .ref-card:focus-visible .ref-img {
    transform: scale(1.05);
  }
  .ref-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 1.5rem;
    text-align: center;
    background: rgba(1, 64, 128, 0.82);
    color: #fff;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .ref-card:hover .ref-overlay,
  .ref-card:focus-visible .ref-overlay {
    opacity: 1;
  }
  .ref-cat {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }
  .ref-title {
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .section-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .lead-max {
    max-width: 640px;
    color: var(--color-blue);
    font-size: 1.1rem;
    margin-top: 1rem;
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(1rem, 2vw, 1.75rem);
    counter-reset: step;
  }
  .step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-bottom: 3px solid var(--color-blue);
    padding-bottom: 1.25rem;
  }
  .step-icon {
    width: 72px;
    height: 72px;
    margin-bottom: 0.9rem;
  }
  .step-no {
    display: block;
    font-weight: 900;
    font-size: 1.6rem;
    color: var(--color-blue);
    margin-bottom: 0.5rem;
  }
  .step h3 {
    font-size: 1.15rem;
    color: var(--color-blue);
    margin-bottom: 0.4rem;
  }
  .step p {
    color: var(--color-blue);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .ang-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    margin-top: clamp(1.75rem, 3.5vw, 2.75rem);
  }

  @media (max-width: 760px) {
    .svc-head {
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }
    .svc-intro {
      flex: 1 1 60%;
    }
    .svc-more {
      flex-basis: 100%;
      white-space: normal;
    }
    .svc-refs,
    .ang-featured {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .steps {
      grid-template-columns: 1fr;
    }
    .svc-refs,
    .ang-featured {
      grid-template-columns: 1fr;
    }
  }
</style>
