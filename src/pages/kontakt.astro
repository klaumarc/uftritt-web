---
import Layout from "../layouts/Layout.astro";
import SubHero from "../components/SubHero.astro";
import KontaktMap from "../components/KontaktMap.astro";
---

<Layout title="Kontakt – Uftritt" description="Schriib eus! Uftritt GmbH, Frauwisstrasse 9, 8493 Saland · 044 500 29 55 · info@uftritt.ch">
  <SubHero
    eyebrow="Kontakt"
    title="Grüezi!"
    lead="Wir freuen uns riesig darauf, von dir zu hören! Kommunikation ist der Schlüssel zu jedem erfolgreichen Projekt. Deshalb sind wir immer für dich da."
    lottie="/lottie/kontakt-sprechblasen.json"
    lottieLabel="Sprechblasen"
  >
    <p class="hero-contact" slot="hero-extra">
      <a href="tel:+41445002955">044 500 29 55</a>
      <a href="mailto:info@uftritt.ch">info@uftritt.ch</a>
    </p>
  </SubHero>

  <section class="section">
    <div class="container">
      <form
        class="kontakt-form"
        name="kontakt"
        method="POST"
        action="/kontakt.php"
        data-reveal
      >
        {/* Spam-Honeypot: für Menschen unsichtbar, Bots füllen es aus */}
        <p class="hp-field" hidden aria-hidden="true">
          <label>Bitte leer lassen: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>
        <p class="kontakt-error" id="kontakt-error" role="alert" hidden>
          Da ist leider etwas schiefgelaufen. Bitte prüfe deine Angaben – oder
          schreib uns direkt an <a href="mailto:info@uftritt.ch">info@uftritt.ch</a>.
        </p>
        <label>
          <span>Name</span>
          <input type="text" name="name" required />
        </label>
        <label>
          <span>E-Mail</span>
          <input type="email" name="email" required />
        </label>
        <label>
          <span>Worum geht's?</span>
          <textarea name="nachricht" rows="5" required></textarea>
        </label>
        <button type="submit" class="kontakt-submit">
          <span class="ks-arrow" aria-hidden="true"><i></i></span>
          <span>Nachricht schickä</span>
        </button>
      </form>
    </div>
  </section>

  <section class="section kontakt-map-section" aria-label="Standort auf Karte">
    <div class="container">
      <header class="section-head" data-reveal>
        <span class="eyebrow">Standort</span>
        <h2>So findest du uns</h2>
      </header>
      <div class="kontakt-loc">
        <div class="kontakt-info" data-reveal>
          <img class="kontakt-photo" src="/kontakt/standort.jpg" alt="Unser Standort an der Frauwisstrasse 9 in Saland" loading="lazy" />
          <address>
            <strong>Uftritt GmbH</strong><br />
            Frauwisstrasse 9<br />
            8493 Saland
          </address>
        </div>
        <div class="kontakt-map" data-reveal>
          <KontaktMap />
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Fehler-Hinweis zeigen, wenn kontakt.php mit ?fehler=1 zurückleitet
  if (new URLSearchParams(location.search).get("fehler") === "1") {
    const el = document.getElementById("kontakt-error");
    if (el) el.hidden = false;
  }
</script>

<style>
  /* Telefon + E-Mail direkt unter dem Lead im Hero */
  .hero-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.75rem;
    margin-top: 1.5rem;
    font-size: clamp(1.15rem, 1.7vw, 1.45rem);
    font-weight: 700;
  }
  .hero-contact a {
    color: var(--color-blue);
  }
  .hero-contact a:hover {
    color: var(--color-pink);
  }

  .kontakt-loc {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  .kontakt-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    margin-bottom: 1.5rem;
  }
  .kontakt-info address {
    font-style: normal;
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--color-blue);
  }
  .kontakt-links {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 1.25rem;
    font-size: 1.2rem;
    font-weight: 700;
  }
  .kontakt-links a {
    color: var(--color-blue);
  }
  .kontakt-links a:hover {
    color: var(--color-pink);
  }

  .kontakt-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 640px;
  }
  .kontakt-error {
    border-left: 3px solid var(--color-pink);
    padding: 0.75rem 1rem;
    color: var(--color-blue);
    font-weight: 600;
  }
  .kontakt-error a {
    color: var(--color-pink);
  }
  .kontakt-form label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--color-blue);
  }
  .kontakt-form input,
  .kontakt-form textarea {
    font-family: var(--font-base);
    font-size: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid #e7ecf3;
    background: #fff;
    color: var(--color-blue);
  }
  .kontakt-form input:focus,
  .kontakt-form textarea:focus {
    outline: none;
    border-color: var(--color-blue);
  }
  .kontakt-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-base);
    font-weight: 700;
    font-size: 1.0625rem;
    line-height: 1;
    color: #fff;
    background: var(--color-blue);
    border: none;
    padding: 1rem 1.7rem;
    cursor: var(--cur-hand);
    transition: background 0.4s var(--ease);
  }
  .kontakt-submit:hover {
    background: var(--color-blue-dark);
  }
  /* Marken-Pfeil gleitet bei Hover rein – wie die anderen Buttons */
  .ks-arrow {
    display: inline-block;
    max-width: 0;
    overflow: visible;
    transition: max-width 0.6s var(--ease), margin-right 0.6s var(--ease);
  }
  .ks-arrow i {
    display: block;
    width: 1.1em;
    height: 0.85em;
    background-color: #fff;
    -webkit-mask: url("/img/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
    mask: url("/img/icons/pfeil-rechts-blau.svg") no-repeat center / contain;
    opacity: 0;
    transform: translateX(-16px);
    transition: opacity 0.5s var(--ease), transform 0.6s var(--ease);
  }
  .kontakt-submit:hover .ks-arrow,
  .kontakt-submit:focus-visible .ks-arrow {
    max-width: 1.1em;
    margin-right: 0.55rem;
  }
  .kontakt-submit:hover .ks-arrow i,
  .kontakt-submit:focus-visible .ks-arrow i {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .ks-arrow,
    .ks-arrow i {
      transition: none;
    }
  }

  .kontakt-map-section {
    padding-top: 0;
  }
  .kontakt-map-section .section-head {
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  .kontakt-map {
    line-height: 0;
    border: 1px solid #e7ecf3;
  }
  .kontakt-map iframe {
    width: 100%;
    height: clamp(320px, 42vw, 520px);
    display: block;
    border: 0;
  }

  @media (max-width: 760px) {
    .kontakt-loc {
      grid-template-columns: 1fr;
    }
  }
</style>
