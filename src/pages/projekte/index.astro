---
import Layout from "../../layouts/Layout.astro";
import SubHero from "../../components/SubHero.astro";
import { projects } from "../../data/projects";

const categories = ["Alle", ...Array.from(new Set(projects.flatMap((p) => p.categories)))];
---

<Layout title="Projekte – Uftritt" description="Eine Auswahl unserer Projekte: Webdesign, Corporate Design, Videoproduktion und mehr aus dem Zürcher Oberland.">
  <SubHero
    eyebrow="Projekte"
    title="Schau mal hier"
    lead="Mit unseren Partnern setzen wir unterschiedlichste Kommunikationslösungen um. Schau dir an, was dabei bereits entstanden ist."
    lottie="/lottie/projekte-rahmen.json"
    lottieLabel="Projekte"
  />

  <section class="section">
    <div class="container">
      <div class="proj-filter" role="tablist" aria-label="Projekte filtern">
        {
          categories.map((cat, i) => (
            <button class:list={["proj-chip", { "is-active": i === 0 }]} type="button" data-filter={cat}>
              {cat}
            </button>
          ))
        }
      </div>

      <div class="project-grid" id="project-grid">
        {
          projects.map((p) => (
            <a href={`/projekte/${p.slug}`} class="project-card" data-cats={p.categories.join(",")} aria-label={p.title}>
              <img class="project-img" src={p.image} alt={p.title} loading="lazy" />
              <span class="project-overlay">
                <span class="project-cat">{p.categories.join(" · ")}</span>
                <span class="project-title">{p.title}</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .proj-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .proj-chip {
    font-family: var(--font-base);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-blue);
    background: transparent;
    border: 2px solid rgba(1, 64, 128, 0.25);
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    transition: background 0.4s var(--ease), color 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  .proj-chip:hover {
    border-color: var(--color-blue);
  }
  .proj-chip.is-active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: #fff;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.75rem);
  }
  .project-card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .project-card.is-hidden {
    display: none;
  }
  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.85s var(--ease);
  }
  .project-card:hover .project-img {
    transform: scale(1.05);
  }
  .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 1.5rem;
    text-align: center;
    background: rgba(1, 64, 128, 0.82);
    color: #fff;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .project-card:hover .project-overlay {
    opacity: 1;
  }
  .project-cat {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }
  .project-title {
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 700;
    line-height: 1.15;
  }

  @media (max-width: 860px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const root = document.querySelector(".proj-filter");
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".proj-chip"));
  const cards = Array.from(document.querySelectorAll<HTMLElement>("#project-grid .project-card"));
  chips.forEach((chip) =>
    chip.addEventListener("click", () => {
      const filter = chip.dataset.filter;
      chips.forEach((c) => c.classList.toggle("is-active", c === chip));
      cards.forEach((card) => {
        const show = filter === "Alle" || (card.dataset.cats || "").split(",").includes(filter);
        card.classList.toggle("is-hidden", !show);
      });
    })
  );
</script>
