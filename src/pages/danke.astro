---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
---

<Layout title="Danke – Uftritt" description="Danke für deine Nachricht – wir melden uns so schnell wie möglich.">
  <section class="danke section--yellow">
    <div class="container danke-inner">
      <h1 data-reveal>Merci!</h1>
      <div class="danke-actions" data-reveal>
        <Button href="/" variant="blue">Zurück zur Startseite</Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .danke {
    min-height: calc(100svh - 76px);
    display: flex;
    align-items: center;
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }
  .danke-inner {
    max-width: 640px;
  }
  .danke .eyebrow {
    display: block;
    margin-bottom: 0.5rem;
  }
  .danke-lead {
    font-size: clamp(1.3rem, 2.1vw, 1.9rem);
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-blue);
    margin-top: 1.5rem;
  }
  .danke-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: clamp(2rem, 4vw, 3rem);
  }
</style>
