---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingCta from "../components/FloatingCta.astro";
import RecallPopup from "../components/RecallPopup.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Uftritt – Agentur für Kommunikation",
  description = "Wir entwickeln Strategien und visuelle Konzepte, die deine DNA spürbar machen. Grafikdesign, Webdesign und Videoproduktion aus dem Zürcher Oberland.",
} = Astro.props;

// Rückruf-Popup nur auf Angebot- und Projekte-Seiten (inkl. aller Unterseiten)
const path = Astro.url.pathname;
const showRecall = path.startsWith("/angebot") || path.startsWith("/projekte");
---

<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingCta />
    {showRecall && <RecallPopup />}

    <script>
      // Sanftes Einblenden beim Scrollen – respektiert reduced-motion
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      const els = document.querySelectorAll("[data-reveal]");
      if (prefersReduced || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -10% 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>

  </body>
</html>
